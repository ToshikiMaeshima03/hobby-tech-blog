---
import Layout from '@/layouts/Layout.astro';
import NewsletterForm from '@/components/NewsletterForm.astro';
import { site } from '@/data/site';

const personSchema = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "mainEntity": {
    "@type": "Person",
    "name": site.author,
    "url": `${site.url}/about/`,
    "description": site.authorDescription,
    "sameAs": [site.social.github, site.social.portfolio].filter(Boolean),
    "jobTitle": "Web Engineer",
    "worksFor": {
      "@type": "Organization",
      "name": "エックスサーバー株式会社",
    },
  },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "ホーム", "item": `${site.url}/` },
    { "@type": "ListItem", "position": 2, "name": "About", "item": `${site.url}/about/` },
  ],
};
---

<Layout title="About" description="Code & Craft の運営者プロフィール。Web制作とフリーランス向けの技術情報を発信しています。">
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />

  <article class="max-w-3xl mx-auto px-4 py-12">
    <!-- Breadcrumb -->
    <nav class="text-sm text-text-muted mb-8" aria-label="パンくずリスト">
      <ol class="flex items-center gap-1.5">
        <li><a href="/" class="hover:text-primary-600">ホーム</a></li>
        <li aria-hidden="true">/</li>
        <li class="text-text" aria-current="page">About</li>
      </ol>
    </nav>

    <!-- Profile Header -->
    <div class="flex flex-col sm:flex-row items-center sm:items-start gap-6 mb-10">
      <div class="shrink-0">
        <div class="w-24 h-24 rounded-full bg-gradient-to-br from-primary-400 to-primary-600 flex items-center justify-center text-4xl font-bold text-white shadow-lg" role="img" aria-label="Cleverのアバター">
          C
        </div>
      </div>
      <div class="text-center sm:text-left">
        <h1 class="text-2xl font-bold mb-1">{site.author}</h1>
        <p class="text-text-muted text-sm mb-3">Web Engineer / {site.name} 運営</p>
        <div class="flex items-center justify-center sm:justify-start gap-3">
          {site.social.github && (
            <a href={site.social.github} target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-sm text-text-muted hover:text-text transition-colors">
              <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              GitHub<span class="sr-only">（新しいタブで開く）</span>
            </a>
          )}
          {site.social.portfolio && (
            <a href={site.social.portfolio} target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-sm text-text-muted hover:text-text transition-colors">
              <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
              Portfolio<span class="sr-only">（新しいタブで開く）</span>
            </a>
          )}
        </div>
      </div>
    </div>

    <!-- About Content -->
    <div class="prose">
      <h2>このブログについて</h2>
      <p>
        <strong>{site.name}</strong> は、Web制作・AI活用・フリーランスの実践的なノウハウを発信するテックブログです。
        「知っていれば10倍速くなる」技術Tipsや、現場で使えるツール比較、副業Web制作のリアルな情報をお届けしています。
      </p>

      <h2>運営者について</h2>
      <p>
        エックスサーバー株式会社の開発部門でエンジニアとして勤務しています。
        WordPressのテーマ・プラグイン開発やWebサービスのパフォーマンス最適化を日常的に担当しています。
      </p>
      <p>
        前職はゲーム業界で7年間フロントエンド開発に従事。
        コンシューマーゲームやモバイルゲームの UI/UX 実装を経験しました。
      </p>

      <h3>技術スタック</h3>
      <ul>
        <li><strong>フロントエンド</strong>: HTML / CSS / JavaScript / TypeScript / React / Astro</li>
        <li><strong>バックエンド</strong>: PHP（WordPress）/ Python / Node.js</li>
        <li><strong>インフラ</strong>: Cloudflare / VPS / Docker</li>
        <li><strong>AI</strong>: Claude Code / ChatGPT を活用した開発効率化</li>
      </ul>

      <h3>得意分野</h3>
      <ul>
        <li>Webサイトのパフォーマンス最適化（Lighthouse 全項目90+）</li>
        <li>WordPress テーマ・プラグイン開発</li>
        <li>LP・コーポレートサイト制作</li>
        <li>AI を活用した開発ワークフロー構築</li>
      </ul>

      <h2>お問い合わせ</h2>
      <p>
        記事の内容に関するご質問や、お仕事のご依頼は
        <a href={site.social.portfolio} target="_blank" rel="noopener noreferrer">ポートフォリオサイト<span class="sr-only">（新しいタブで開く）</span></a>
        よりお気軽にお問い合わせください。
      </p>
    </div>

    <!-- Newsletter -->
    <div class="mt-12">
      <NewsletterForm variant="hero" />
    </div>

    <!-- Back link -->
    <div class="mt-10">
      <a href="/" class="text-primary-600 hover:text-primary-700 font-medium text-sm">
        &larr; ホームに戻る
      </a>
    </div>
  </article>
</Layout>
