---
import Layout from '@/layouts/Layout.astro';
import PostCard from '@/components/PostCard.astro';
import { getCollection } from 'astro:content';
import { site } from '@/data/site';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 12);

const featuredPosts = allPosts.filter(p => p.data.featured).slice(0, 3);
---

<Layout>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-primary-50 to-surface py-16">
    <div class="max-w-5xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-4xl font-bold mb-4 text-text">
        Web制作とフリーランスの<br class="hidden md:block" />技術ナレッジベース
      </h1>
      <p class="text-text-muted max-w-2xl mx-auto">
        {site.description}
      </p>
    </div>
  </section>

  <!-- Categories -->
  <section class="max-w-5xl mx-auto px-4 -mt-6">
    <div class="flex flex-wrap justify-center gap-2">
      {site.categories.map(cat => (
        <a
          href={`/blog?category=${cat.slug}`}
          class="text-sm px-4 py-2 rounded-full border border-border bg-surface hover:border-primary-300 hover:bg-primary-50 transition-all"
        >
          {cat.name}
        </a>
      ))}
    </div>
  </section>

  <!-- Featured -->
  {featuredPosts.length > 0 && (
    <section class="max-w-5xl mx-auto px-4 mt-12">
      <h2 class="text-xl font-bold mb-6">注目の記事</h2>
      <div class="grid md:grid-cols-3 gap-5">
        {featuredPosts.map(post => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            slug={post.id}
            category={post.data.category}
            publishedAt={post.data.publishedAt}
            tags={post.data.tags}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Latest Posts -->
  <section class="max-w-5xl mx-auto px-4 py-12">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-xl font-bold">最新記事</h2>
      <a href="/blog" class="text-sm text-primary-600 hover:text-primary-700 font-medium">
        すべての記事 &rarr;
      </a>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {posts.map(post => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          slug={post.id}
          category={post.data.category}
          publishedAt={post.data.publishedAt}
          tags={post.data.tags}
        />
      ))}
    </div>
  </section>
</Layout>
