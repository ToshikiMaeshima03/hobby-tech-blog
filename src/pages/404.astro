---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="ページが見つかりません" noindex={true}>
  <section class="max-w-3xl mx-auto px-4 py-24 text-center" aria-labelledby="error-heading">
    <h1 id="error-heading" class="text-6xl font-bold text-primary-300 mb-4">
      <span aria-hidden="true">404</span>
      <span class="sr-only">ページが見つかりません（404エラー）</span>
    </h1>
    <p class="text-xl text-text-muted mb-8">お探しのページは見つかりませんでした。</p>
    <a href="/" class="inline-block px-6 py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors font-medium">
      ホームに戻る
    </a>
  </section>
</Layout>
