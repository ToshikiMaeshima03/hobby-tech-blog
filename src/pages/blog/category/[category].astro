---
import Layout from '@/layouts/Layout.astro';
import PostCard from '@/components/PostCard.astro';
import { getCollection } from 'astro:content';
import { site } from '@/data/site';

export async function getStaticPaths() {
  return site.categories.map(cat => ({
    params: { category: cat.slug },
    props: { category: cat },
  }));
}

const { category } = Astro.props;
const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts
  .filter(p => p.data.category === category.slug)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const categoryCount: Record<string, number> = {};
for (const post of allPosts) {
  categoryCount[post.data.category] = (categoryCount[post.data.category] || 0) + 1;
}

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "ホーム", "item": `${site.url}/` },
    { "@type": "ListItem", "position": 2, "name": "記事一覧", "item": `${site.url}/blog/` },
    { "@type": "ListItem", "position": 3, "name": category.name, "item": `${site.url}/blog/category/${category.slug}/` },
  ],
};
---

<Layout title={`${category.name}の記事一覧`} description={`${category.description}に関する記事一覧`}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />

  <section class="max-w-5xl mx-auto px-4 py-12">
    <!-- Breadcrumb -->
    <nav class="text-sm text-text-muted mb-8" aria-label="パンくずリスト">
      <ol class="flex items-center gap-1.5">
        <li><a href="/" class="hover:text-primary-600">ホーム</a></li>
        <li aria-hidden="true">/</li>
        <li><a href="/blog/" class="hover:text-primary-600">記事一覧</a></li>
        <li aria-hidden="true">/</li>
        <li class="text-text" aria-current="page">{category.name}</li>
      </ol>
    </nav>

    <h1 class="text-2xl font-bold mb-2">{category.name}</h1>
    <p class="text-text-muted mb-8">{category.description} - {posts.length} 件の記事</p>

    <!-- Category filter -->
    <div class="flex flex-wrap gap-2 mb-8">
      <a
        href="/blog/"
        class="text-sm px-3 py-1.5 rounded-full border border-border hover:border-primary-300 hover:bg-primary-50 transition-all"
      >
        すべて
      </a>
      {site.categories.map(cat => (
        <a
          href={`/blog/category/${cat.slug}/`}
          class:list={[
            'text-sm px-3 py-1.5 rounded-full border transition-all',
            cat.slug === category.slug
              ? 'border-primary-300 bg-primary-50 text-primary-700 font-medium'
              : 'border-border hover:border-primary-300 hover:bg-primary-50',
          ]}
          aria-current={cat.slug === category.slug ? 'page' : undefined}
        >
          {cat.name} ({categoryCount[cat.slug] || 0})
        </a>
      ))}
    </div>

    <!-- Posts grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {posts.map(post => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          slug={post.id}
          category={post.data.category}
          publishedAt={post.data.publishedAt}
          tags={post.data.tags}
        />
      ))}
    </div>

    {posts.length === 0 && (
      <p class="text-center text-text-muted py-12">このカテゴリにはまだ記事がありません。</p>
    )}
  </section>
</Layout>
